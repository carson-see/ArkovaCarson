# Arkova Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials

# ─── Frontend (Vite requires VITE_ prefix for client-side variables) ───
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_WORKER_URL=http://localhost:3001
VITE_SENTRY_DSN=
VITE_APP_URL=http://localhost:5173
VITE_APP_VERSION=0.1.0
VITE_BITCOIN_NETWORK=signet

# Optional: Stripe publishable key
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# ─── Worker (services/worker) ───
NODE_ENV=development
WORKER_PORT=3001
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
USE_MOCKS=false

# Supabase (worker — no VITE_ prefix)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Bitcoin
BITCOIN_TREASURY_WIF=your-treasury-wif-here
BITCOIN_NETWORK=signet
BITCOIN_RPC_URL=
BITCOIN_RPC_AUTH=

# Legacy chain API (backward compat)
CHAIN_API_URL=
CHAIN_API_KEY=
CHAIN_NETWORK=testnet

# KMS Signing
KMS_PROVIDER=
GCP_KMS_PROJECT_ID=
GCP_KMS_KEY_RESOURCE_NAME=

# Verification API (Phase 1.5)
ENABLE_VERIFICATION_API=false
API_KEY_HMAC_SECRET=your-hmac-secret-here
CORS_ALLOWED_ORIGINS=*

# AI / Gemini (P8)
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Sentry (worker)
SENTRY_DSN=
SENTRY_SAMPLE_RATE=0.1

# Cloudflare (edge workers)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# AI Fallback (edge worker only)
ENABLE_AI_FALLBACK=false

# Feature Flags
ENABLE_PROD_NETWORK_ANCHORING=false
