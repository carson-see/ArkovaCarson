# Arkova Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials

# ─── Frontend (Vite requires VITE_ prefix for client-side variables) ───
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_WORKER_URL=http://localhost:3001
VITE_SENTRY_DSN=
VITE_APP_URL=http://localhost:5173
VITE_APP_VERSION=0.1.0
VITE_BITCOIN_NETWORK=mainnet

# Optional: Stripe publishable key
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# ─── Worker (services/worker) ───
NODE_ENV=development
WORKER_PORT=3001
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
USE_MOCKS=false

# Supabase (worker — no VITE_ prefix)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_POOLER_URL=                     # Transaction-mode pooler URL (Cloud Run production)
SUPABASE_JWT_SECRET=                     # JWT secret for token verification

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Bitcoin
BITCOIN_TREASURY_WIF=your-treasury-wif-here
# Options: signet (recommended), testnet4, testnet, mainnet
BITCOIN_NETWORK=signet
BITCOIN_RPC_URL=
BITCOIN_RPC_AUTH=

# Bitcoin Fee Estimation
BITCOIN_FEE_STRATEGY=                  # "static" | "mempool" (live API)
BITCOIN_STATIC_FEE_RATE=               # sat/vB when strategy is static
BITCOIN_FALLBACK_FEE_RATE=             # sat/vB fallback when live estimation fails
BITCOIN_MAX_FEE_RATE=                  # sat/vB ceiling — anchors queued above this
FORCE_DYNAMIC_FEE_ESTIMATION=false     # Force live fee estimation on testnet

# Legacy chain API (backward compat)
CHAIN_API_URL=
CHAIN_API_KEY=
CHAIN_NETWORK=testnet

# KMS Signing
KMS_PROVIDER=
GCP_KMS_PROJECT_ID=
GCP_KMS_KEY_RESOURCE_NAME=

# KMS (mainnet signing)
BITCOIN_KMS_KEY_ID=                    # AWS KMS key ID
BITCOIN_KMS_REGION=                    # AWS KMS region

# Proof Bundle Signing (SCRUM-900 / PROOF-SIG-01)
# `/api/v1/verify/:publicId/proof?format=signed` returns an Ed25519-signed
# bundle. Resolution order: PROOF_SIGNING_KMS_KEY (production — GCP KMS,
# private key never leaves KMS) → PROOF_SIGNING_KEY_PEM (dev/preview/tests
# only, NEVER set in prod) → unsigned 503. PROOF_SIGNING_KEY_ID is the
# public-facing identifier carried in the bundle and the matching entry
# in docs/public-keys.json. Required when either signing path is enabled.
PROOF_SIGNING_KEY_ID=                  # e.g. arkova-proof-2026-04
PROOF_SIGNING_KMS_KEY=                 # GCP KMS key version resource name
PROOF_SIGNING_KEY_PEM=                 # dev only: Ed25519 private key PEM

# Verification API (Phase 1.5)
ENABLE_VERIFICATION_API=false
API_KEY_HMAC_SECRET=your-hmac-secret-here
CORS_ALLOWED_ORIGINS=*

# AI / Gemini (P8)
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Nessie (RunPod vLLM)
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=

# Email
RESEND_API_KEY=                        # Resend transactional email
EMAIL_FROM=noreply@arkova.ai           # Verified sender address

# Data Pipeline
MEMPOOL_API_URL=                       # mempool.space API URL override
EDGAR_USER_AGENT=                      # SEC EDGAR User-Agent (required by SEC)

# Sentry
SENTRY_DSN=
SENTRY_SAMPLE_RATE=0.1
SENTRY_AUTH_TOKEN=
SENTRY_ORG=arkova
SENTRY_PROJECT=arkova-frontend

# Cloudflare (edge workers)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# AI Fallback (edge worker only)
ENABLE_AI_FALLBACK=false

# Cron Auth
CRON_SECRET=                             # min 16 chars, secures scheduled endpoints
CRON_OIDC_AUDIENCE=                      # OIDC audience for Cloud Scheduler cron

# Feature Flags
ENABLE_PROD_NETWORK_ANCHORING=false
ENABLE_AI_EXTRACTION=false
ENABLE_SEMANTIC_SEARCH=false

# Beta gate (set to restrict signups to invited users only; leave empty to allow open signups)
VITE_BETA_INVITE_CODE=
