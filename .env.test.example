# Test Environment Variables
# Copy to .env.test and fill in values before running E2E or RLS tests.
# NEVER commit .env.test — it is gitignored.

# ---- E2E Tests ----

# Required: Service role key for test data setup/teardown (bypasses RLS)
E2E_SUPABASE_SERVICE_KEY=

# Required: Shared password for all seed test users
E2E_SEED_PASSWORD=

# Optional: Supabase API URL (defaults to local instance http://127.0.0.1:54321)
# E2E_SUPABASE_URL=

# ---- RLS Integration Tests ----

# Required: Supabase connection details for RLS tests
# For local dev, use the well-known Supabase local dev JWTs from: https://supabase.com/docs/guides/cli/local-development
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required: Password matching seed.sql demo users
RLS_TEST_PASSWORD=
