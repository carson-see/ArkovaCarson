{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["services/worker/**"],
    "buildCommand": "cd services/worker && npm ci && npm run build"
  },
  "deploy": {
    "startCommand": "cd services/worker && node dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
