{
  "name": "arkova",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.14.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:copy": "tsx scripts/check-copy-terms.ts",
    "gen:types": "supabase gen types typescript --local > src/types/database.types.ts",
    "ci:api-contract-drift": "tsx scripts/ci/check-api-contract-drift.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:rls": "vitest run --config vitest.config.rls.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "vitest run tests/load",
    "analyze": "ANALYZE=true vite build && echo 'Bundle report: dist/bundle-stats.html'",
    "healthcheck": "tsx scripts/healthcheck/index.ts",
    "audit:secrets": "tsx scripts/secrets/audit-env.ts",
    "ci:api-scope-vocabulary": "tsx scripts/ci/check-api-scope-vocabulary.ts",
    "ci:dep-pinning": "tsx scripts/ci/check-dep-pinning.ts",
    "ci:duplicate-artifacts": "tsx scripts/ci/check-duplicate-artifacts.ts",
    "ci:retry-after-429": "tsx scripts/ci/check-retry-after-429.ts",
    "ci:sonar-quality-gate": "tsx scripts/ci/check-sonar-quality-gate.ts",
    "security:license-denylist": "tsx scripts/security/license-denylist.ts package-lock.json services/worker/package-lock.json",
    "ci:staging-evidence": "tsx scripts/ci/check-staging-evidence.ts",
    "staging:seed": "tsx scripts/staging/seed.ts",
    "staging:load": "tsx scripts/staging/load-harness.ts",
    "staging:claim": "./scripts/staging/claim.sh",
    "staging:teardown": "./scripts/staging/teardown-and-reset.sh"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/react": "10.51.0",
    "@stripe/stripe-js": "9.4.0",
    "@supabase/supabase-js": "2.105.3",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-virtual": "3.13.24",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jspdf": "4.2.1",
    "lucide-react": "1.14.0",
    "pdfjs-dist": "5.7.284",
    "qrcode.react": "4.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "7.15.0",
    "read-excel-file": "9.0.9",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "tesseract.js": "7.0.0",
    "tla-precheck": "0.1.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@cloudflare/workers-types": "4.20260505.1",
    "@eslint/compat": "2.0.5",
    "@eslint/js": "9.24.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@playwright/test": "1.59.1",
    "@sentry/vite-plugin": "5.2.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/eslint": "9.6.1",
    "@types/node": "25.6.0",
    "@types/pdfjs-dist": "2.10.378",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "10.5.0",
    "dotenv": "17.4.2",
    "esbuild": "0.28.0",
    "eslint": "10.3.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-arkova": "file:./eslint-rules",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.14",
    "rollup-plugin-visualizer": "7.0.1",
    "supabase": "2.98.2",
    "tailwindcss": "3.4.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "wrangler": "4.88.0"
  },
  "overrides": {
    "minimatch@<3.1.3": "3.1.5",
    "minimatch@>=9.0.0 <9.0.7": "9.0.7",
    "undici": "7.24.2"
  }
}
