# Worker Service Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials

# ── Server ───────────────────────────────────────
WORKER_PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── Supabase (required) ─────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional: JWT secret for local token verification (eliminates network call)
# SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Stripe (required for payments) ──────────────
STRIPE_SECRET_KEY=sk_test_your-test-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ── Bitcoin Chain ────────────────────────────────
BITCOIN_NETWORK=signet
BITCOIN_UTXO_PROVIDER=mempool
# BITCOIN_TREASURY_WIF=your-treasury-wif-here
# BITCOIN_RPC_URL=http://localhost:18443
# BITCOIN_RPC_AUTH=user:password
# MEMPOOL_API_URL=https://mempool.space/signet/api

# ── Fee Estimation ───────────────────────────────
# BITCOIN_FEE_STRATEGY=static
# BITCOIN_STATIC_FEE_RATE=2
# BITCOIN_FALLBACK_FEE_RATE=5

# ── AWS KMS (mainnet signing) ───────────────────
# KMS_PROVIDER=aws
# BITCOIN_KMS_KEY_ID=your-kms-key-id
# BITCOIN_KMS_REGION=us-east-1

# ── GCP KMS (alternative mainnet signing) ───────
# KMS_PROVIDER=gcp
# GCP_KMS_KEY_RING=arkova-keys
# GCP_KMS_KEY_NAME=bitcoin-signing
# GCP_KMS_LOCATION=us-east1

# ── Frontend ─────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Cloudflare Tunnel (Zero Trust ingress) ───────
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ── Sentry ───────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project
# SENTRY_SAMPLE_RATE=0.1

# ── Verification API ────────────────────────────
ENABLE_VERIFICATION_API=false
API_KEY_HMAC_SECRET=your-hmac-secret-here-min-32-chars
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Cron Authentication ─────────────────────────
# CRON_SECRET=your-cron-secret-here-min-16-chars
# CRON_OIDC_AUDIENCE=https://your-cloud-run-url

# ── AI / Gemini (P8) ───────────────────────────
AI_PROVIDER=mock
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── x402 Payment Protocol (USDC on Base) ─────────
# X402_FACILITATOR_URL=https://x402.org/facilitator
# ARKOVA_USDC_ADDRESS=
# X402_NETWORK=eip155:84532

# ── Nessie Training Pipeline ─────────────────────
# EDGAR_USER_AGENT=Arkova contact@arkova.io
# TRAINING_DATA_OUTPUT_PATH=./training-data

# ── Feature Flags ────────────────────────────────
USE_MOCKS=true
ENABLE_PROD_NETWORK_ANCHORING=false
# ENABLE_AI_EXTRACTION=false
# ENABLE_SEMANTIC_SEARCH=false
# ENABLE_AI_FRAUD=false
# ENABLE_BATCH_ANCHORING=false
